{
  "display_information": {
    "name": "LaunchBot"
  },
  "features": {
    "bot_user": {
      "display_name": "LaunchBot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/launch",
        "description": "Kick off a product launch workflow",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "chat:write",
        "commands"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}