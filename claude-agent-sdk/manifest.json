{
  "display_information": {
    "name": "LaunchBot",
    "description": "Launch coordination bot with AI agent capabilities"
  },
  "features": {
    "assistant_view": {
      "assistant_description": "Hi, I am an agent built using Bolt for JavaScript. I am here to help you out!",
      "suggested_prompts": []
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "LaunchBot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/launch",
        "description": "Kick off a product launch workflow",
        "usage_hint": "[\"launch-name\"] date:YYYY-MM-DD tier:major|moderate|minor",
        "should_escape": false
      },
      {
        "command": "/launch-phase",
        "description": "Manually force a phase transition",
        "usage_hint": "status | set <phase>",
        "should_escape": false
      },
      {
        "command": "/retro",
        "description": "Trigger the post-launch retro early",
        "usage_hint": "(run inside a launch channel)",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": ["https://ngrok-free.app/slack/oauth_redirect"],
    "scopes": {
      "user": [
        "search:read",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "mpim:history",
        "users:read",
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "canvases:read",
        "canvases:write",
        "users:read.email"
      ],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:join",
        "channels:manage",
        "channels:read",
        "chat:write",
        "chat:write.public",
        "commands",
        "groups:history",
        "groups:read",
        "groups:write",
        "im:history",
        "im:read",
        "im:write",
        "reactions:write",
        "reactions:read",
        "users:read",
        "usergroups:read",
        "assistant:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://ngrok-free.app/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://ngrok-free.app/slack/events"
    },
    "is_mcp_enabled": true,
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
