{
  "display_information": {
    "name": "LaunchBot",
    "description": "Launch coordination bot with AI agent capabilities"
  },
  "features": {
    "bot_user": {
      "display_name": "LaunchBot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/signals",
        "description": "Manage product-demand signal clusters",
        "usage_hint": "cluster | list [status] | show <id> | validate <id> | dismiss <id>",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "channels:join",
        "channels:read",
        "chat:write",
        "commands",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "app_mentions:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.im",
        "message.channels",
        "message.groups",
        "app_mention",
        "app_home_opened",
        "assistant_thread_started"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}