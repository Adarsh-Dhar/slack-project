{
  "display_information": {
    "name": "Launchpad",
    "description": "Launch coordination bot for Slack",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "Launchpad",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/launch",
        "description": "Kick off a product launch workflow",
        "usage_hint": "[launch-name] [date YYYY-MM-DD]",
        "should_escape": false
      },
      {
        "command": "/agent",
        "description": "Ask the LaunchPad AI agent a question",
        "usage_hint": "[your question]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "channels:read",
        "channels:manage",
        "chat:write",
        "chat:write.public",
        "commands",
        "groups:history",
        "groups:read",
        "groups:write",
        "im:write",
        "im:read",
        "im:history",
        "users:read",
        "canvases:write",
        "canvases:read",
        "conversations.connect:write",
        "bookmarks:write",
        "bookmarks:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups",
        "member_joined_channel"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
